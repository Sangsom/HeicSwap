<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Secret keys injected from build settings (sourced from .secrets → Secrets.xcconfig).
	  These live in a real Info.plist because GENERATE_INFOPLIST_FILE only honors known
	  Apple INFOPLIST_KEY_* names; custom keys must be declared here, where $(VAR) expands.
	  All Apple/standard keys are still generated (GENERATE_INFOPLIST_FILE = YES) and merged in.
	-->
	<key>REVENUECAT_API_KEY</key>
	<string>$(REVENUECAT_API_KEY)</string>
	<key>TELEMETRYDECK_APP_ID</key>
	<string>$(TELEMETRYDECK_APP_ID)</string>
</dict>
</plist>
